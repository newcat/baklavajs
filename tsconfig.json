{
    "compilerOptions": {
        "target": "ES2022",
        "module": "preserve",
        "strict": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "exclude": ["node_modules"]
}
