{
    "name": "baklavajs",
    "version": "2.8.1",
    "description": "Full installation of BaklavaJS including the core and all plugins",
    "author": "newcat <freddy.wagner@web.de>",
    "homepage": "https://newcat.github.io/baklavajs",
    "license": "MIT",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./bundle": "./dist/bundle.js"
    },
    "scripts": {
        "build:esm": "esbuild src/index.ts src/bundle.ts --outdir=dist/esm --format=esm --sourcemap",
        "build:cjs": "esbuild src/index.ts src/bundle.ts --outdir=dist/cjs --format=cjs --sourcemap",
        "build:types": "tsc -p tsconfig.build.json",
        "build:browser": "esbuild src/bundle.ts --bundle --minify --sourcemap --global-name=BaklavaJS --outfile=dist/bundle.js",
        "build": "rimraf dist && pnpm run build:esm && pnpm run build:cjs && pnpm run build:types && echo '{\"type\":\"module\"}' > dist/esm/package.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json && pnpm run build:browser"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/newcat/baklavajs.git"
    },
    "bugs": {
        "url": "https://github.com/newcat/baklavajs/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@baklavajs/core": "^2.8.1",
        "@baklavajs/engine": "^2.8.1",
        "@baklavajs/interface-types": "^2.8.1",
        "@baklavajs/renderer-vue": "^2.8.1",
        "@baklavajs/themes": "^2.8.1"
    },
    "devDependencies": {
        "typescript": "^6.0.2",
        "vue": "^3.5.22"
    }
}
