{
    "name": "@baklavajs/engine",
    "version": "2.8.1",
    "description": "Execute BaklavaJS graphs",
    "author": "newcat <freddy.wagner@web.de>",
    "homepage": "https://newcat.github.io/baklavajs",
    "license": "MIT",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "scripts": {
        "build:esm": "esbuild src/*.ts --outdir=dist/esm --format=esm --sourcemap",
        "build:cjs": "esbuild src/*.ts --outdir=dist/cjs --format=cjs --sourcemap",
        "build:types": "tsc -p tsconfig.build.json",
        "build": "rimraf dist && pnpm run build:esm && pnpm run build:cjs && pnpm run build:types && echo '{\"type\":\"module\"}' > dist/esm/package.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "test": "vitest run --coverage"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/newcat/baklavajs.git"
    },
    "bugs": {
        "url": "https://github.com/newcat/baklavajs/issues"
    },
    "dependencies": {
        "@baklavajs/core": "^2.8.1",
        "@baklavajs/events": "^2.8.0"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.0.6",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.2",
        "vitest": "^4.0.6"
    },
    "publishConfig": {
        "access": "public"
    },
    "gitHead": "723bf8b6249e6b67d9a7a5a9c84cf1ee0ca33739"
}
